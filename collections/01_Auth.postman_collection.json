{
  "info": {
    "_postman_id": "col-auth-001",
    "name": "01 - Authentication",
    "description": "JWT-based authentication flow: login, token validation, negative tests, and logout simulation for a SaaS backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "🔐 Login - Valid Credentials",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Log environment being tested",
              "console.log('🚀 Auth test running on:', pm.environment.get('environment'));",
              "// Timestamp for test run tracking",
              "pm.globals.set('test_run_id', Date.now());"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();",
              "",
              "pm.test('✅ Status 200 - Login Successful', () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('✅ Response contains token', () => {",
              "  pm.expect(jsonData).to.have.property('token');",
              "  pm.expect(jsonData.token).to.be.a('string').and.not.empty;",
              "});",
              "",
              "pm.test('✅ Token is a valid JWT (3-part structure)', () => {",
              "  const parts = jsonData.token.split('.');",
              "  pm.expect(parts.length).to.eql(3);",
              "});",
              "",
              "pm.test('✅ Response time < 2000ms', () => {",
              "  pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "// Chain token to environment for subsequent requests",
              "if (jsonData.token) {",
              "  pm.environment.set('access_token', jsonData.token);",
              "  console.log('🔑 Token stored:', jsonData.token.substring(0, 20) + '...');",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{auth_url}}/auth/login",
          "host": ["{{auth_url}}"],
          "path": ["auth", "login"]
        },
        "description": "Authenticate with valid credentials. Token is extracted and stored in environment for chained requests."
      }
    },
    {
      "name": "🔐 Login - Invalid Password (Negative)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('✅ Status is 4xx for invalid credentials', () => {",
              "  pm.expect(pm.response.code).to.be.oneOf([400, 401, 403, 500]);",
              "});",
              "",
              "pm.test('✅ Response body is not empty', () => {",
              "  pm.expect(pm.response.text()).to.not.be.empty;",
              "});",
              "",
              "pm.test('✅ No token returned on invalid login', () => {",
              "  try {",
              "    const body = pm.response.json();",
              "    pm.expect(body.token).to.be.undefined;",
              "  } catch (e) {",
              "    // Non-JSON response is also acceptable for error cases",
              "    pm.expect(true).to.be.true;",
              "  }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"WRONG_PASSWORD_123!\"\n}"
        },
        "url": {
          "raw": "{{auth_url}}/auth/login",
          "host": ["{{auth_url}}"],
          "path": ["auth", "login"]
        },
        "description": "Negative test: login with wrong password. Validates error handling."
      }
    },
    {
      "name": "🔐 Login - Missing Username (Negative)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('✅ Status is 4xx for missing username', () => {",
              "  pm.expect(pm.response.code).to.be.oneOf([400, 401, 403, 500]);",
              "});",
              "",
              "pm.test('✅ Error response is not empty', () => {",
              "  pm.expect(pm.response.text()).to.not.be.empty;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"password\": \"somepassword\"\n}"
        },
        "url": {
          "raw": "{{auth_url}}/auth/login",
          "host": ["{{auth_url}}"],
          "path": ["auth", "login"]
        },
        "description": "Negative test: missing required username field."
      }
    },
    {
      "name": "🔐 Login - Empty Body (Edge Case)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('✅ Empty body returns error or 4xx', () => {",
              "  pm.expect(pm.response.code).to.be.oneOf([400, 401, 403, 500]);",
              "});",
              "",
              "pm.test('✅ Response time under threshold', () => {",
              "  pm.expect(pm.response.responseTime).to.be.below(3000);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}"
        },
        "url": {
          "raw": "{{auth_url}}/auth/login",
          "host": ["{{auth_url}}"],
          "path": ["auth", "login"]
        },
        "description": "Edge case: empty JSON body submitted for authentication."
      }
    }
  ]
}
