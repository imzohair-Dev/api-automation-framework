{
  "info": {
    "_postman_id": "col-products-003",
    "name": "03 - Product Catalog (CRUD)",
    "description": "Full product lifecycle: browse catalog, filter by category, CRUD operations, schema validation, and edge cases.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🛍️ Get All Products",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "console.log('🛒 Product catalog test - ENV:', pm.environment.get('environment'));"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();",
              "",
              "pm.test('✅ Status 200 - Products fetched', () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('✅ Response is a non-empty array', () => {",
              "  pm.expect(jsonData).to.be.an('array');",
              "  pm.expect(jsonData.length).to.be.greaterThan(0);",
              "});",
              "",
              "pm.test('✅ Product schema is valid', () => {",
              "  jsonData.forEach(product => {",
              "    pm.expect(product).to.have.property('id');",
              "    pm.expect(product).to.have.property('title');",
              "    pm.expect(product).to.have.property('price');",
              "    pm.expect(product).to.have.property('category');",
              "    pm.expect(product).to.have.property('image');",
              "    pm.expect(product).to.have.property('rating');",
              "  });",
              "});",
              "",
              "pm.test('✅ Product prices are positive numbers', () => {",
              "  jsonData.forEach(product => {",
              "    pm.expect(product.price).to.be.a('number').and.above(0);",
              "  });",
              "});",
              "",
              "pm.test('✅ Rating has rate and count', () => {",
              "  jsonData.forEach(product => {",
              "    pm.expect(product.rating).to.have.property('rate');",
              "    pm.expect(product.rating).to.have.property('count');",
              "    pm.expect(product.rating.rate).to.be.within(0, 5);",
              "  });",
              "});",
              "",
              "pm.test('✅ Response time < 2000ms', () => {",
              "  pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "// Store first product ID for chaining",
              "if (jsonData.length > 0) {",
              "  pm.environment.set('product_id', jsonData[0].id);",
              "  console.log('📦 Stored product_id:', jsonData[0].id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/products",
          "host": ["{{base_url}}"],
          "path": ["products"]
        }
      }
    },
    {
      "name": "📦 Get Single Product",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();",
              "",
              "pm.test('✅ Status 200 - Product fetched', () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('✅ Product has all required fields', () => {",
              "  pm.expect(jsonData).to.have.property('id');",
              "  pm.expect(jsonData).to.have.property('title');",
              "  pm.expect(jsonData).to.have.property('price');",
              "  pm.expect(jsonData).to.have.property('description');",
              "  pm.expect(jsonData).to.have.property('category');",
              "  pm.expect(jsonData).to.have.property('image');",
              "  pm.expect(jsonData).to.have.property('rating');",
              "});",
              "",
              "pm.test('✅ Product title is non-empty string', () => {",
              "  pm.expect(jsonData.title).to.be.a('string').and.not.empty;",
              "});",
              "",
              "pm.test('✅ Image URL is valid', () => {",
              "  pm.expect(jsonData.image).to.match(/^https?:\\/\\/.+/);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/products/{{product_id}}",
          "host": ["{{base_url}}"],
          "path": ["products", "{{product_id}}"]
        }
      }
    },
    {
      "name": "🏷️ Get Products by Category",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();",
              "",
              "pm.test('✅ Status 200 - Category products fetched', () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('✅ All products belong to requested category', () => {",
              "  jsonData.forEach(product => {",
              "    pm.expect(product.category).to.eql('electronics');",
              "  });",
              "});",
              "",
              "pm.test('✅ At least one product returned', () => {",
              "  pm.expect(jsonData.length).to.be.greaterThan(0);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/products/category/electronics",
          "host": ["{{base_url}}"],
          "path": ["products", "category", "electronics"]
        }
      }
    },
    {
      "name": "📋 Get All Categories",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();",
              "",
              "pm.test('✅ Status 200 - Categories fetched', () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('✅ Response is an array of strings', () => {",
              "  pm.expect(jsonData).to.be.an('array');",
              "  jsonData.forEach(cat => pm.expect(cat).to.be.a('string'));",
              "});",
              "",
              "pm.test('✅ Expected categories are present', () => {",
              "  pm.expect(jsonData).to.include('electronics');",
              "  pm.expect(jsonData).to.include('jewelery');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/products/categories",
          "host": ["{{base_url}}"],
          "path": ["products", "categories"]
        }
      }
    },
    {
      "name": "➕ Create Product",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const productTitles = ['Pro Wireless Keyboard', 'Ultra HD Monitor 4K', 'Ergonomic Office Chair', 'Mechanical Gaming Mouse'];",
              "const randomTitle = productTitles[Math.floor(Math.random() * productTitles.length)];",
              "const randomPrice = (Math.random() * 500 + 10).toFixed(2);",
              "pm.variables.set('random_title', randomTitle);",
              "pm.variables.set('random_price', randomPrice);",
              "console.log('🎲 Generated product:', randomTitle, '$' + randomPrice);"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();",
              "",
              "pm.test('✅ Status 200/201 - Product created', () => {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});",
              "",
              "pm.test('✅ New product has an ID', () => {",
              "  pm.expect(jsonData).to.have.property('id');",
              "  pm.environment.set('created_product_id', jsonData.id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"{{random_title}}\",\n  \"price\": {{random_price}},\n  \"description\": \"A high-quality product for modern professionals, tested and validated by QA.\",\n  \"image\": \"https://fakestoreapi.com/img/placeholder.jpg\",\n  \"category\": \"electronics\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/products",
          "host": ["{{base_url}}"],
          "path": ["products"]
        }
      }
    },
    {
      "name": "✏️ Update Product (PUT)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('✅ Status 200 - Product updated', () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('✅ Updated product has valid schema', () => {",
              "  const jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.have.property('id');",
              "  pm.expect(jsonData).to.have.property('title');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Updated QA Test Product\",\n  \"price\": 99.99,\n  \"description\": \"Updated description via PUT method - QA validated\",\n  \"image\": \"https://fakestoreapi.com/img/placeholder.jpg\",\n  \"category\": \"electronics\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/products/{{product_id}}",
          "host": ["{{base_url}}"],
          "path": ["products", "{{product_id}}"]
        }
      }
    },
    {
      "name": "🗑️ Delete Product",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('✅ Status 200 - Product deleted', () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('✅ Deleted product ID in response', () => {",
              "  const jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.have.property('id');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "url": {
          "raw": "{{base_url}}/products/{{product_id}}",
          "host": ["{{base_url}}"],
          "path": ["products", "{{product_id}}"]
        }
      }
    },
    {
      "name": "🔢 Get Products - Sorted DESC",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();",
              "",
              "pm.test('✅ Status 200 - Sorted products returned', () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('✅ Products returned in descending order', () => {",
              "  for (let i = 0; i < jsonData.length - 1; i++) {",
              "    pm.expect(jsonData[i].id).to.be.greaterThan(jsonData[i + 1].id);",
              "  }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/products?sort=desc",
          "host": ["{{base_url}}"],
          "path": ["products"],
          "query": [{ "key": "sort", "value": "desc" }]
        }
      }
    },
    {
      "name": "🚫 Invalid Category Filter (Negative)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('✅ Invalid category returns empty array or error', () => {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 400, 404]);",
              "  if (pm.response.code === 200) {",
              "    const body = pm.response.json();",
              "    pm.expect(body).to.be.an('array');",
              "    pm.expect(body.length).to.eql(0);",
              "  }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/products/category/nonexistent_category_xyz",
          "host": ["{{base_url}}"],
          "path": ["products", "category", "nonexistent_category_xyz"]
        }
      }
    }
  ]
}
